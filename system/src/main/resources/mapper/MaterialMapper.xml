<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.app.mapper.MaterialMapper">

    <resultMap id="BaseResultMap" type="com.app.entity.Material">
        <id column="id" property="id"/>
        <result column="code" property="code"/>
        <result column="name" property="name"/>
        <result column="spec" property="spec"/>
        <result column="unit" property="unit"/>
        <result column="stock_quantity" property="stockQuantity"/>
        <result column="safety_stock" property="safetyStock"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM material WHERE id = #{id}
    </select>

    <select id="selectByCode" resultMap="BaseResultMap">
        SELECT * FROM material WHERE code = #{code}
    </select>

    <select id="selectList" resultMap="BaseResultMap">
        SELECT * FROM material
        <where>
            <if test="keyword != null and keyword != ''">
                AND (name LIKE CONCAT('%', #{keyword}, '%') OR code LIKE CONCAT('%', #{keyword}, '%'))
            </if>
        </where>
        ORDER BY create_time DESC
    </select>

    <select id="selectWarningList" resultMap="BaseResultMap">
        SELECT * FROM material WHERE stock_quantity &lt; safety_stock
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO material (code, name, spec, unit, stock_quantity, safety_stock)
        VALUES (#{code}, #{name}, #{spec}, #{unit}, #{stockQuantity}, #{safetyStock})
    </insert>

    <update id="updateById">
        UPDATE material
        <set>
            <if test="code != null">code = #{code},</if>
            <if test="name != null">name = #{name},</if>
            <if test="spec != null">spec = #{spec},</if>
            <if test="unit != null">unit = #{unit},</if>
            <if test="stockQuantity != null">stock_quantity = #{stockQuantity},</if>
            <if test="safetyStock != null">safety_stock = #{safetyStock},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM material WHERE id = #{id}
    </delete>

    <update id="updateStockQuantity">
        UPDATE material SET stock_quantity = #{stockQuantity} WHERE id = #{id}
    </update>

    <select id="countAll" resultType="int">
        SELECT COUNT(*) FROM material
    </select>

</mapper>
